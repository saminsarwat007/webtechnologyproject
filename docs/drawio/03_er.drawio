        <!-- ============================ RELATIONSHIPS (crow's foot) ============================ -->

        <!-- users 1:1 profiles ("has") -->
        <mxCell id="rel_has" value="has" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.2;exitY=1;entryX=0.2;entryY=0;startArrow=ERone;startFill=0;endArrow=ERone;endFill=0;strokeColor=#000000;fontSize=11;fontStyle=1;" edge="1" parent="1" source="users" target="profiles"><mxGeometry relative="1" as="geometry"/></mxCell>

