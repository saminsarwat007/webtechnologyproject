        <mxCell id="rel_posts" value="posts" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.85;entryX=0;entryY=0.3;startArrow=ERone;startFill=0;endArrow=ERmany;endFill=0;strokeColor=#000000;fontSize=11;fontStyle=1;" edge="1" parent="1" source="users" target="jobs">
