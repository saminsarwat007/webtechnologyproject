        <!-- jobs 1:N applications ("receives") - right then up -->
        <mxCell id="rel_receives" value="receives" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;entryX=0.5;entryY=1;startArrow=ERone;startFill=0;endArrow=ERmany;endFill=0;strokeColor=#000000;fontSize=11;fontStyle=1;" edge="1" parent="1" source="jobs" target="applications">
